# Copy to .env.local for local dev (vercel dev), and set the same two vars in
# the Vercel project: Settings → Environment Variables.
#
# Find these in Supabase: Dashboard → Project Settings → API
#   SUPABASE_URL                = Project URL
#   SUPABASE_SERVICE_ROLE_KEY   = service_role secret (NOT the anon key — keep secret)

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
